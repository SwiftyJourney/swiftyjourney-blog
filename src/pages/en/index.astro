---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroBlog from "../../components/HeroBlog.astro";
import ArticleList from "../../components/ArticleList.astro";
import Pagination from "../../components/Pagination.astro";
import { getPublishedPosts } from "../../utils/posts";

const PAGE_SIZE = 10;

const allPosts = await getPublishedPosts();
const posts = allPosts
  .filter((post) => post.data.lang === "en")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.ceil(posts.length / PAGE_SIZE);
const pagePosts = posts.slice(0, PAGE_SIZE);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Swifty Journey — Writing",
  description: "Real-world iOS engineering, explained clearly.",
  url: "https://blog.swiftyjourney.com/en/",
  inLanguage: "en",
  publisher: {
    "@type": "Person",
    name: "Juan Francisco Dorado Torres",
    url: "https://swiftyjourney.com",
    sameAs: [
      "https://x.com/jfdoradotr",
      "https://github.com/swiftyjourney",
      "https://linkedin.com/in/juanfranciscodoradotorres",
    ],
  },
  blogPost: pagePosts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    datePublished: post.data.pubDate.toISOString(),
    url: `https://blog.swiftyjourney.com/en/blog/${post.data.slug}/`,
  })),
};
---

<BaseLayout
  title="Swifty Journey — Writing"
  description="Real-world iOS engineering, explained clearly."
  lang="en"
  jsonLd={jsonLd}
>
  <HeroBlog
    title="Writing about Swift."
    subtitle="Real-world iOS engineering, explained clearly."
  />

  <ArticleList posts={pagePosts} lang="en" />

  <Pagination currentPage={1} totalPages={totalPages} baseUrl="/en/" />
</BaseLayout>
