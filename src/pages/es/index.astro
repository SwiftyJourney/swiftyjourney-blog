---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroBlog from "../../components/HeroBlog.astro";
import ArticleList from "../../components/ArticleList.astro";
import Pagination from "../../components/Pagination.astro";
import { getPublishedPosts } from "../../utils/posts";

const PAGE_SIZE = 10;

const allPosts = await getPublishedPosts();
const posts = allPosts
  .filter((post) => post.data.lang === "es")
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.ceil(posts.length / PAGE_SIZE);
const pagePosts = posts.slice(0, PAGE_SIZE);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Swifty Journey — Escritura",
  description: "Ingeniería iOS real, explicada con claridad.",
  url: "https://blog.swiftyjourney.com/es/",
  inLanguage: "es",
  publisher: {
    "@type": "Person",
    name: "Juan Francisco Dorado Torres",
    url: "https://swiftyjourney.com",
    sameAs: [
      "https://x.com/jfdoradotr",
      "https://github.com/swiftyjourney",
      "https://linkedin.com/in/juanfranciscodoradotorres",
    ],
  },
  blogPost: pagePosts.map((post) => ({
    "@type": "BlogPosting",
    headline: post.data.title,
    datePublished: post.data.pubDate.toISOString(),
    url: `https://blog.swiftyjourney.com/es/blog/${post.data.slug}/`,
  })),
};
---

<BaseLayout
  title="Swifty Journey — Escritura"
  description="Ingeniería iOS real, explicada con claridad."
  lang="es"
  jsonLd={jsonLd}
>
  <HeroBlog
    title="Escribo sobre Swift."
    subtitle="Ingeniería iOS real, explicada con claridad."
  />

  <ArticleList posts={pagePosts} lang="es" />

  <Pagination currentPage={1} totalPages={totalPages} baseUrl="/es/" />
</BaseLayout>
