---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HeroBlog from "../../../components/HeroBlog.astro";
import ArticleList from "../../../components/ArticleList.astro";
import { getPublishedPosts } from "../../../utils/posts";
import { slugify } from "../../../utils/slugify";

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  const posts = allPosts.filter((post) => post.data.lang === "es");
  const tagMap = new Map<string, string>();

  for (const post of posts) {
    for (const tag of post.data.tags ?? []) {
      const slug = slugify(tag);
      if (!slug) continue;
      if (!tagMap.has(slug)) tagMap.set(slug, tag);
    }
  }

  return Array.from(tagMap.entries()).map(([slug, label]) => ({
    params: { tag: slug },
    props: { tagSlug: slug, tagLabel: label },
  }));
}

const { tagSlug, tagLabel } = Astro.props;
const allPosts = await getPublishedPosts();
const posts = allPosts
  .filter((post) => post.data.lang === "es")
  .filter((post) =>
    (post.data.tags ?? []).some((tag) => slugify(tag) === tagSlug),
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const count = posts.length;
const countLabel = `${count} artículo${count === 1 ? "" : "s"}`;
---

<BaseLayout
  title={`${tagLabel} — Swifty Journey`}
  description={`Escritura etiquetada con ${tagLabel}.`}
  lang="es"
>
  <HeroBlog
    eyebrow="Etiqueta"
    title={tagLabel}
    subtitle={countLabel}
  />

  <ArticleList posts={posts} lang="es" />
</BaseLayout>
