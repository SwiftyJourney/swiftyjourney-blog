---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HeroBlog from "../../../components/HeroBlog.astro";
import { getPublishedPosts } from "../../../utils/posts";
import { slugify } from "../../../utils/slugify";

const allPosts = await getPublishedPosts();
const posts = allPosts.filter((post) => post.data.lang === "es");

const tagMap = new Map<string, { label: string; count: number }>();
for (const post of posts) {
  for (const tag of post.data.tags ?? []) {
    const slug = slugify(tag);
    if (!slug) continue;
    const entry = tagMap.get(slug) ?? { label: tag, count: 0 };
    tagMap.set(slug, { label: entry.label, count: entry.count + 1 });
  }
}

const tags = Array.from(tagMap.entries())
  .map(([slug, info]) => ({ slug, ...info }))
  .sort((a, b) => b.count - a.count || a.label.localeCompare(b.label));
---

<BaseLayout
  title="Etiquetas — Swifty Journey"
  description="Explora la escritura por tema."
  lang="es"
>
  <HeroBlog title="Etiquetas." subtitle="Explora la escritura por tema." />

  <section class="max-w-[640px] mx-auto pb-24">
    {tags.length === 0 ? (
      <p class="text-text-muted">Aún no hay etiquetas.</p>
    ) : (
      <ul class="list-none p-0 m-0 divide-y divide-border">
        {tags.map((tag) => (
          <li>
            <a
              href={`/es/tags/${tag.slug}/`}
              class="group flex items-center justify-between py-5 md:py-6 transition-colors"
            >
              <span class="text-[14px] font-medium uppercase tracking-[0.08em] text-text group-hover:text-accent transition-colors">
                {tag.label}
              </span>
              <span class="text-[12px] tabular-nums text-text-subtle group-hover:text-text-muted transition-colors">
                {tag.count}
              </span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
