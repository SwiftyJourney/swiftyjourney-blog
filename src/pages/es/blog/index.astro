---
import { getPublishedPosts } from "../../../utils/posts";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCard from "../../../components/BlogCard.astro";
import Pagination from "../../../components/Pagination.astro";

const PAGE_SIZE = 9;
const currentPage = 1;

const allPosts = await getPublishedPosts();
const posts = allPosts
	.filter((post) => post.data.lang === "es")
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.ceil(posts.length / PAGE_SIZE);
const pagePosts = posts.slice(0, PAGE_SIZE);

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	name: "Blog — Swifty Journey",
	description: "Todos los artículos sobre iOS, Swift y SwiftUI",
	url: "https://blog.swiftyjourney.com/es/blog/",
	inLanguage: "es",
	publisher: { "@type": "Person", name: "Juan Francisco Dorado Torres" },
	itemListElement: pagePosts.map((post, i) => ({
		"@type": "ListItem",
		position: i + 1,
		url: `https://blog.swiftyjourney.com/es/blog/${post.data.slug}/`,
		name: post.data.title,
	}))
};
---

<BaseLayout
	title="Blog — Swifty Journey"
	description="Todos los artículos sobre iOS, Swift y SwiftUI"
	lang="es"
	jsonLd={jsonLd}
>
	<div class="py-12">
		<div class="mb-12">
			<h1
				class="text-3xl md:text-4xl font-bold text-zinc-900 dark:text-zinc-100 mb-4"
			>
				Todos los Artículos
			</h1>
			<p class="text-zinc-600 dark:text-zinc-400">
				Explora todos nuestros artículos sobre iOS, Swift y SwiftUI
			</p>
		</div>

		{pagePosts.length > 0 && (
			<BlogCard post={pagePosts[0]} featured={true} lang="es" />
		)}

		{pagePosts.length > 1 && (
			<div class="grid gap-6 md:grid-cols-2 mt-8">
				{pagePosts.slice(1).map((post) => (
					<BlogCard post={post} lang="es" />
				))}
			</div>
		)}

		<Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/es/blog/" />
	</div>
</BaseLayout>
