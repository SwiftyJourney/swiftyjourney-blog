---
import type { CollectionEntry } from "astro:content";
import { getPublishedPosts } from "../utils/posts";
import BaseLayout from "./BaseLayout.astro";
import Meta from "../components/Meta.astro";
import ArticleRow from "../components/ArticleRow.astro";

type Props = CollectionEntry<"blog">["data"] & {
  lang?: "en" | "es";
  translationKey?: string;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  lang = "es",
  translationKey,
  tags,
  slug,
} = Astro.props;

const siteUrl = Astro.site?.toString() ?? "https://blog.swiftyjourney.com";
const canonical = new URL(Astro.url.pathname, siteUrl).toString();

const allPosts = await getPublishedPosts();
const translatedPost = allPosts.find(
  (post) =>
    post.data.translationKey === translationKey && post.data.lang !== lang,
);

const normalizeTag = (tag: string) =>
  tag
    .trim()
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const currentTagSlugs = tags?.map(normalizeTag) ?? [];
const relatedByTags =
  currentTagSlugs.length > 0
    ? allPosts.filter(
        (post) =>
          post.data.lang === lang &&
          post.data.slug !== slug &&
          (post.data.tags ?? []).some((tag) =>
            currentTagSlugs.includes(normalizeTag(tag)),
          ),
      )
    : [];

const relatedPosts =
  relatedByTags.length > 0
    ? relatedByTags
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
        .slice(0, 3)
    : allPosts
        .filter(
          (post) => post.data.lang === lang && post.data.slug !== slug,
        )
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
        .slice(0, 3);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  keywords: tags?.join(", "),
  inLanguage: lang,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  mainEntityOfPage: canonical,
  author: {
    "@type": "Person",
    name: "Juan Francisco Dorado Torres",
    url: "https://swiftyjourney.com",
    sameAs: [
      "https://x.com/jfdoradotr",
      "https://github.com/swiftyjourney",
      "https://linkedin.com/in/juanfranciscodoradotorres",
    ],
  },
  publisher: {
    "@type": "Person",
    name: "Juan Francisco Dorado Torres",
    url: "https://swiftyjourney.com",
  },
};

const toEn =
  translatedPost && lang === "es"
    ? `/en/blog/${translatedPost.data.slug ?? translatedPost.id.split("/").pop()}/`
    : "/en/";
const toEs =
  translatedPost && lang === "en"
    ? `/es/blog/${translatedPost.data.slug ?? translatedPost.id.split("/").pop()}/`
    : "/es/";

const backLabel = lang === "en" ? "Back to writing" : "Volver a escritura";
const relatedLabel = lang === "en" ? "Related" : "Relacionados";
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  toEn={toEn}
  toEs={toEs}
  seoType="article"
  articlePublishedTime={pubDate.toISOString()}
  articleModifiedTime={updatedDate ? updatedDate.toISOString() : undefined}
  jsonLd={jsonLd}
>
  <article class="max-w-[680px] mx-auto px-4 py-16 md:py-24">
    <header class="mb-14">
      <Meta pubDate={pubDate} tags={tags} lang={lang} />
      <h1
        class="mt-6 text-display-md md:text-display-lg font-semibold tracking-tight text-text"
      >
        {title}
      </h1>
      {description && (
        <p class="mt-5 text-lead text-text-muted">{description}</p>
      )}
      {updatedDate && (
        <p
          class="mt-4 text-[12px] uppercase tracking-[0.08em] text-text-subtle"
        >
          <time datetime={updatedDate.toISOString()}>
            {lang === "en" ? "Updated" : "Actualizado"}{" "}
            {updatedDate.toLocaleDateString(
              lang === "en" ? "en-US" : "es-MX",
              { year: "numeric", month: "long", day: "numeric" },
            )}
          </time>
        </p>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>

    {relatedPosts.length > 0 && (
      <section class="mt-20 pt-10 border-t border-border">
        <h2
          class="text-[12px] font-medium uppercase tracking-[0.08em] text-text-muted mb-10"
        >
          {relatedLabel}
        </h2>
        <ul class="list-none p-0 m-0 flex flex-col gap-10">
          {relatedPosts.map((post) => (
            <li>
              <ArticleRow post={post} lang={lang} compact />
            </li>
          ))}
        </ul>
      </section>
    )}

    <footer class="mt-16 pt-8 border-t border-border">
      <a
        href={`/${lang}/`}
        class="inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent transition-colors"
      >
        ← {backLabel}
      </a>
    </footer>
  </article>
</BaseLayout>
