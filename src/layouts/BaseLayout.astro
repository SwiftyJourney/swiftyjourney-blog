---
import "../styles/global.css";
import LangToggle from "../components/LangToggle.astro";
import SEO from "../components/SEO.astro";
import EDLogo from "../components/EDLogo.astro";
import { Icon } from "astro-icon/components";

const SITE = "https://blog.swiftyjourney.com";
const MAIN_SITE = "https://swiftyjourney.com";

type Lang = "en" | "es";

const {
  title = "Swifty Journey — Writing",
  description = "Real-world iOS engineering, explained clearly.",
  lang = "en" as Lang,
  toEn: customToEn,
  toEs: customToEs,
  seoTitle,
  seoDescription,
  seoImage,
  seoType = "website",
  articlePublishedTime,
  articleModifiedTime,
  jsonLd,
} = Astro.props;

const path = Astro.url.pathname || "/";

const slugMap: Record<Lang, Record<string, string>> = {
  en: { resources: "recursos" },
  es: { recursos: "resources" },
};

function translateFirstSegment(
  currentLang: Lang,
  otherLang: Lang,
  pathname: string,
) {
  const bare = pathname.replace(/^\/(en|es)\//, "");
  const parts = bare.split("/").filter(Boolean);
  if (parts.length === 0) return `/${otherLang}/`;
  const first = parts[0];
  const mapped = (slugMap[currentLang] && slugMap[currentLang][first]) || first;
  const rebuilt = `/${otherLang}/${[mapped, ...parts.slice(1)].join("/")}`;
  return rebuilt.endsWith("/") ? rebuilt : rebuilt + "/";
}

const isEN =
  path.startsWith("/en/") ||
  (!path.startsWith("/en/") && !path.startsWith("/es/"));
const isES = path.startsWith("/es/");
const currentLang: Lang = isEN ? "en" : "es";

const toEn =
  customToEn || (isEN ? path : translateFirstSegment("es", "en", path));
const toEs =
  customToEs || (isES ? path : translateFirstSegment("en", "es", path));

const canonical = new URL(path, SITE).toString();
const hrefEn = new URL(toEn, SITE).toString();
const hrefEs = new URL(toEs, SITE).toString();

const homeHref = lang === "en" ? "/en/" : "/es/";
const tagsHref = lang === "en" ? "/en/tags/" : "/es/tags/";
const resourcesHref = lang === "en" ? "/en/resources/" : "/es/recursos/";
const aboutHref = lang === "en" ? `${MAIN_SITE}/en/about/` : `${MAIN_SITE}/es/about/`;
const siteHomeHref = lang === "en" ? `${MAIN_SITE}/en/` : `${MAIN_SITE}/es/`;

const tagsLabel = lang === "en" ? "Tags" : "Etiquetas";
const resourcesLabel = lang === "en" ? "Resources" : "Recursos";
const aboutLabel = lang === "en" ? "About" : "Sobre mí";
const wordmark = lang === "en" ? "Writing" : "Escritura";
const backToSiteLabel = lang === "en" ? "swiftyjourney.com" : "swiftyjourney.com";
---

<html lang={lang} class="min-h-full" transition:animate="fade">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <SEO
      title={seoTitle || title}
      description={seoDescription || description}
      canonical={canonical}
      image={seoImage}
      type={seoType}
      lang={lang}
      jsonLd={jsonLd}
    />

    <link rel="alternate" href={hrefEn} hreflang="en" />
    <link rel="alternate" href={hrefEs} hreflang="es-mx" />
    <link rel="alternate" href={SITE + "/"} hreflang="x-default" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Swifty Journey Blog"
      href="/rss.xml"
    />

    <link rel="icon" href="/favicon.svg" />

    <link rel="dns-prefetch" href="//github.com" />
    <link rel="dns-prefetch" href="//x.com" />
    <link rel="dns-prefetch" href="//linkedin.com" />
    <link rel="dns-prefetch" href="//swiftyjourney.com" />

    <link rel="prefetch" href={lang === "en" ? "/es/" : "/en/"} />

    <link rel="preload" href="/logo.svg" as="image" type="image/svg+xml" />
    <link
      rel="preload"
      href="/fonts/Inter-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/Inter-SemiBold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    {articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}

    <style>
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation-duration: 0.3s;
      }
      ::view-transition-old(root) { animation-name: fade-out; }
      ::view-transition-new(root) { animation-name: fade-in; }
      @keyframes fade-out { from { opacity: 1; } to { opacity: 0; } }
      @keyframes fade-in { from { opacity: 0; } to { opacity: 1; } }
    </style>
  </head>

  <body class="antialiased">
    <header
      class="sticky top-0 z-50 backdrop-blur supports-[backdrop-filter]:bg-bg/70"
    >
      <div
        class="max-w-6xl mx-auto px-4 py-3 md:py-4 flex items-center justify-between"
      >
        <a
          href={homeHref}
          class="flex items-center gap-2"
          aria-label="Swifty Journey — Writing"
          transition:persist="logo"
        >
          <img
            src="/logo.svg"
            alt="Swifty Journey"
            width="192"
            height="48"
            class="h-10 md:h-12 w-auto block"
          />
          <span class="hidden sm:inline text-sm text-text-subtle tracking-wide"
            >/ {wordmark}</span
          >
        </a>

        <nav
          class="flex items-center gap-1 md:gap-2"
          transition:persist="navigation"
        >
          <a
            href={tagsHref}
            class="px-3 py-1.5 text-sm text-text-muted hover:text-text rounded-md transition-colors"
          >
            {tagsLabel}
          </a>
          <a
            href={resourcesHref}
            class="hidden md:inline-block px-3 py-1.5 text-sm text-text-muted hover:text-text rounded-md transition-colors"
          >
            {resourcesLabel}
          </a>
          <a
            href={aboutHref}
            class="px-3 py-1.5 text-sm text-text-muted hover:text-text rounded-md transition-colors"
          >
            {aboutLabel}
          </a>
          <LangToggle lang={lang} toEn={toEn} toEs={toEs} />
        </nav>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-4">
      <slot />
    </main>

    <footer
      class="max-w-6xl mx-auto px-4 py-12 border-t border-border mt-20"
    >
      <div class="flex flex-col items-center gap-5 text-text-muted">
        <div class="flex gap-5 text-2xl">
          <a
            href="https://github.com/swiftyjourney"
            target="_blank"
            rel="noopener me"
            aria-label="GitHub"
            class="hover:text-text transition-colors"
          >
            <Icon name="mdi:github" />
          </a>
          <a
            href="https://x.com/jfdoradotr"
            target="_blank"
            rel="noopener me"
            aria-label="X"
            class="hover:text-text transition-colors"
          >
            <Icon name="mdi:twitter" />
          </a>
          <a
            href="https://linkedin.com/in/juanfranciscodoradotorres"
            target="_blank"
            rel="noopener me"
            aria-label="LinkedIn"
            class="hover:text-text transition-colors"
          >
            <Icon name="mdi:linkedin" />
          </a>
        </div>

        <a
          href="https://iosacademy.essentialdeveloper.com/p/ios-lead-essentials/"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-xs text-text-subtle hover:text-text transition-colors"
        >
          <EDLogo class="h-3.5 w-auto" />
          <span>Moderator — iOS Lead Essentials (2022)</span>
        </a>

        <p class="text-sm">
          © {new Date().getFullYear()} Swifty Journey — Juan F. Dorado.
        </p>

        <a
          href={siteHomeHref}
          class="text-xs text-text-subtle hover:text-accent transition-colors"
        >
          ← {backToSiteLabel}
        </a>
      </div>
    </footer>

  </body>
</html>
