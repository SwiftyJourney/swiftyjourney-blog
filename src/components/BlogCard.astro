---
import { Image } from "astro:assets";
import { slugify } from "../utils/slugify";

interface Props {
	post: any;
	featured?: boolean;
	lang: "es" | "en";
}

const { post, featured = false, lang } = Astro.props;
const locale = lang === "es" ? "es-ES" : "en-US";
const slug = post.data.slug ?? post.id.split("/").pop();
---

<article class="group">
	<a href={`/${lang}/blog/${slug}/`} class="block">
		{featured ? (
			<div class="rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden transition-all hover:border-orange-500/30 hover:shadow-lg md:flex md:gap-0">
				{post.data.heroImage && (
					<div class="md:w-1/2">
						<Image
							src={post.data.heroImage}
							alt={post.data.title}
							width={720}
							height={360}
							class="w-full h-56 md:h-full object-cover"
							loading="eager"
						/>
					</div>
				)}
				<div class={`p-6 md:p-8 ${post.data.heroImage ? "md:w-1/2 md:flex md:flex-col md:justify-center" : ""}`}>
					<h2 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-3 group-hover:text-orange-500 transition-colors">
						{post.data.title}
					</h2>
					<p class="text-zinc-600 dark:text-zinc-400 mb-4 text-base line-clamp-3">
						{post.data.description}
					</p>
					{post.data.tags && post.data.tags.length > 0 && (
						<div class="mb-4 flex flex-wrap gap-2">
							{post.data.tags.map((tag: string) => (
								<span class="text-[11px] uppercase tracking-wide px-2.5 py-1 rounded-full border border-zinc-200 dark:border-zinc-700 text-zinc-600 dark:text-zinc-300">
									{tag}
								</span>
							))}
						</div>
					)}
					<time class="text-sm text-zinc-500">
						{post.data.pubDate.toLocaleDateString(locale, {
							year: "numeric",
							month: "long",
							day: "numeric",
						})}
					</time>
				</div>
			</div>
		) : (
			<div class="rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden transition-all hover:border-orange-500/30 hover:shadow-md h-full flex flex-col">
				{post.data.heroImage && (
					<div class="aspect-video overflow-hidden">
						<Image
							src={post.data.heroImage}
							alt={post.data.title}
							width={480}
							height={270}
							class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300"
							loading="lazy"
						/>
					</div>
				)}
				<div class="p-5 flex flex-col flex-1">
					<h2 class="text-lg font-bold text-zinc-900 dark:text-zinc-100 mb-2 group-hover:text-orange-500 transition-colors line-clamp-2">
						{post.data.title}
					</h2>
					<p class="text-zinc-600 dark:text-zinc-400 text-sm mb-3 line-clamp-2 flex-1">
						{post.data.description}
					</p>
					{post.data.tags && post.data.tags.length > 0 && (
						<div class="mb-3 flex flex-wrap gap-1.5">
							{post.data.tags.map((tag: string) => (
								<span class="text-[10px] uppercase tracking-wide px-2 py-0.5 rounded-full border border-zinc-200 dark:border-zinc-700 text-zinc-500 dark:text-zinc-400">
									{tag}
								</span>
							))}
						</div>
					)}
					<time class="text-xs text-zinc-500">
						{post.data.pubDate.toLocaleDateString(locale, {
							year: "numeric",
							month: "long",
							day: "numeric",
						})}
					</time>
				</div>
			</div>
		)}
	</a>
</article>
