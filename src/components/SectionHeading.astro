---
type Props = {
  eyebrow?: string;
  title: string;
  lede?: string;
  align?: "left" | "center";
  as?: "h2" | "h3";
};

const { eyebrow, title, lede, align = "left", as = "h2" } = Astro.props;
const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
const Tag = as;
---

<header class={`max-w-[640px] ${alignClass}`}>
  {eyebrow && (
    <p class="text-[12px] font-semibold uppercase tracking-[0.15em] text-accent mb-3">
      {eyebrow}
    </p>
  )}
  <Tag class="text-2xl md:text-3xl font-semibold tracking-tight text-text">
    {title}
  </Tag>
  {lede && (
    <p class="mt-3 text-base text-text-muted leading-relaxed">
      {lede}
    </p>
  )}
</header>
