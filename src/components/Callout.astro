---
import { Icon } from "astro-icon/components";

interface Props {
  type?: "info" | "warning" | "success" | "error" | "tip";
  title?: string;
}

const { type = "info", title } = Astro.props;

const config: Record<
  string,
  { icon: string; border: string; accent: string }
> = {
  tip: {
    icon: "mdi:lightbulb",
    border: "border-accent",
    accent: "text-accent",
  },
  info: {
    icon: "mdi:information",
    border: "border-accent",
    accent: "text-accent",
  },
  warning: {
    icon: "mdi:alert",
    border: "border-amber-600",
    accent: "text-amber-700",
  },
  success: {
    icon: "mdi:check-circle",
    border: "border-emerald-600",
    accent: "text-emerald-700",
  },
  error: {
    icon: "mdi:alert-circle",
    border: "border-red-600",
    accent: "text-red-700",
  },
};

const c = config[type] ?? config.info;
---

<aside
  class={`callout my-7 pl-5 py-4 pr-4 border-l-2 bg-surface-alt/60 rounded-r-md ${c.border}`}
>
  <div class="flex items-start gap-3">
    <Icon name={c.icon} class={`w-5 h-5 mt-0.5 flex-shrink-0 ${c.accent}`} />
    <div class="flex-1 min-w-0">
      {title && (
        <p
          class={`text-[12px] font-semibold uppercase tracking-[0.08em] mb-2 ${c.accent}`}
        >
          {title}
        </p>
      )}
      <div class="callout-body text-[15px] leading-relaxed text-text">
        <slot />
      </div>
    </div>
  </div>
</aside>

<style>
  .callout-body :global(p) {
    margin: 0.5rem 0;
  }
  .callout-body :global(p:first-child) {
    margin-top: 0;
  }
  .callout-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .callout-body :global(code) {
    font-size: 0.875em;
  }
</style>
