---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div
  class="info-box-component my-7 bg-surface border border-border rounded-md p-5 md:p-6"
>
  <div
    class="flex items-center gap-2 mb-4 text-[12px] font-semibold uppercase tracking-[0.08em] text-text-muted"
  >
    <span class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0"></span>
    {title}
  </div>
  <div class="info-box-grid grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3">
    <slot />
  </div>
</div>

<style>
  .info-box-grid :global(ul) {
    list-style: none;
    display: contents;
    padding: 0;
    margin: 0;
  }

  .info-box-grid :global(li),
  .info-box-grid :global(p) {
    position: relative;
    padding-left: 22px;
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
    color: var(--color-text);
  }

  .info-box-grid :global(li)::before {
    content: "→";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-accent);
    font-weight: 600;
    line-height: 1.6;
  }

  .info-box-grid :global(code) {
    font-size: 0.9em;
    white-space: nowrap;
  }
</style>
