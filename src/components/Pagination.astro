---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}

const { currentPage, totalPages, baseUrl } = Astro.props;

const prevUrl =
  currentPage === 2
    ? baseUrl
    : currentPage > 2
      ? `${baseUrl}page/${currentPage - 1}/`
      : null;
const nextUrl =
  currentPage < totalPages ? `${baseUrl}page/${currentPage + 1}/` : null;

const pages: (number | "...")[] = [];
for (let i = 1; i <= totalPages; i++) {
  if (
    i === 1 ||
    i === totalPages ||
    (i >= currentPage - 1 && i <= currentPage + 1)
  ) {
    pages.push(i);
  } else if (pages[pages.length - 1] !== "...") {
    pages.push("...");
  }
}

const pageUrl = (page: number) => (page === 1 ? baseUrl : `${baseUrl}page/${page}/`);
---

{totalPages > 1 && (
  <nav
    class="flex items-center justify-center gap-4 mt-16 pt-8 border-t border-border max-w-[640px] mx-auto"
    aria-label="Pagination"
  >
    {prevUrl ? (
      <a
        href={prevUrl}
        class="text-sm text-text-muted hover:text-accent transition-colors"
        aria-label="Previous page"
      >
        ← Prev
      </a>
    ) : (
      <span class="text-sm text-text-subtle cursor-not-allowed" aria-hidden="true">
        ← Prev
      </span>
    )}

    <ul class="flex items-center gap-3 list-none p-0 m-0">
      {pages.map((page) => (
        <li>
          {page === "..." ? (
            <span class="text-sm text-text-subtle px-1">…</span>
          ) : page === currentPage ? (
            <span
              class="text-sm font-semibold text-accent px-1"
              aria-current="page"
            >
              {page}
            </span>
          ) : (
            <a
              href={pageUrl(page)}
              class="text-sm text-text-muted hover:text-accent transition-colors px-1"
            >
              {page}
            </a>
          )}
        </li>
      ))}
    </ul>

    {nextUrl ? (
      <a
        href={nextUrl}
        class="text-sm text-text-muted hover:text-accent transition-colors"
        aria-label="Next page"
      >
        Next →
      </a>
    ) : (
      <span class="text-sm text-text-subtle cursor-not-allowed" aria-hidden="true">
        Next →
      </span>
    )}
  </nav>
)}
