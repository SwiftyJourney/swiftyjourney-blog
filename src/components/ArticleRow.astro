---
import type { CollectionEntry } from "astro:content";
import Meta from "./Meta.astro";

type Props = {
  post: CollectionEntry<"blog">;
  lang: "en" | "es";
  compact?: boolean;
};

const { post, lang, compact = false } = Astro.props;
const slug = post.data.slug ?? post.id.split("/").pop();
const href = `/${lang}/blog/${slug}/`;

const titleSize = compact
  ? "text-lg md:text-xl"
  : "text-[22px] md:text-[26px]";
const descSize = compact ? "text-sm" : "text-[15px] md:text-base";
---

<a href={href} class="group block focus:outline-none">
  <article class="flex flex-col gap-3 text-left">
    <Meta
      pubDate={post.data.pubDate}
      tags={post.data.tags}
      lang={lang}
      interactive={false}
    />
    <h2
      class={`${titleSize} font-semibold tracking-tight text-text group-hover:text-accent transition-colors`}
    >
      {post.data.title}
    </h2>
    {post.data.description && (
      <p class={`${descSize} text-text-muted leading-snug`}>
        {post.data.description}
      </p>
    )}
    <span
      class="text-accent opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all text-sm"
      aria-hidden="true"
    >
      →
    </span>
  </article>
</a>
