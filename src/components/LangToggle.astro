---
type Props = {
  lang: "en" | "es";
  toEn: string;
  toEs: string;
};
const { lang, toEn, toEs } = Astro.props;

const isES = lang === "es";
const targetHref = isES ? toEn : toEs;
const flag = isES ? "🇺🇸" : "🇲🇽";
const label = isES ? "Switch to English" : "Cambiar a español";
---

<a
  href={targetHref}
  aria-label={label}
  class="text-lg rounded-md px-2 py-1 border border-border hover:border-border-strong transition-colors focus:outline-none focus:ring-2 focus:ring-coral-500/40"
>
  {flag}
</a>
